[Unit]
Description=SonarDeals radar secure refresh queue consumer
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/sonardeals-radar/radar_poller.py
Restart=always
RestartSec=10
User=root
Group=root
Environment=PYTHONUNBUFFERED=1
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/sonardeals-radar /home/krt/car_deal_finder /srv/sonardeals-radar /run/lock

[Install]
WantedBy=multi-user.target
